{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "cd /home/user/typing && npm install",
						"timeout": 60,
						"statusMessage": "npm install 中..."
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "/home/user/typing/.claude/stop-lint-build-check.sh",
						"timeout": 120,
						"statusMessage": "ESLint / Biome / Build チェック中..."
					}
				]
			}
		]
	}
}
